---
/**
 * BlogList.astro - Listagem de Posts do Blog
 * 
 * Página de listagem de posts seguindo o mesmo padrão de design da home.
 * Grid responsivo com cards modernos.
 */

import MainLayout from '../../layouts/MainLayout.astro';

interface Props {
    posts: any[];
    themeId: string;
}

const { posts, themeId } = Astro.props;
---

<MainLayout title="Blog — Artigos e Novidades">
    
    <!-- HERO SECTION -->
    <section class="relative min-h-[60vh] flex items-center justify-center pt-24 md:pt-32 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-black via-black to-[#0a0a0a]">
            <div class="absolute inset-0 opacity-30">
                <div class="absolute inset-0" style="background-image: linear-gradient(to right, rgba(168, 85, 247, 0.1) 1px, transparent 1px), linear-gradient(to bottom, rgba(168, 85, 247, 0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            </div>
            <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
            <div class="absolute bottom-1/3 right-1/4 w-[400px] h-[400px] bg-secondary/8 rounded-full blur-[100px] animate-pulse" style="animation-delay: 1.5s;"></div>
        </div>
        
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-5xl mx-auto text-center">
                <div class="inline-flex items-center gap-2 px-5 py-2.5 mb-10 rounded-full border border-primary/40 bg-primary/10 backdrop-blur-sm">
                    <span class="text-sm md:text-base font-semibold text-primary tracking-wide">📝 Blog</span>
                </div>
                
                <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-black text-white leading-[1.1] mb-8">
                    Últimas <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Novidades</span>
                </h1>
                
                <p class="text-lg md:text-xl lg:text-2xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
                    Artigos sobre desenvolvimento web, SEO, JAMstack e tecnologia
                </p>
            </div>
        </div>
        
        <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-black via-black/80 to-transparent"></div>
    </section>

    <!-- POSTS GRID -->
    <section class="py-20 md:py-32 bg-[#0a0a0a] relative overflow-hidden">
        <div class="container mx-auto px-6">
            {posts.length === 0 ? (
                <div class="text-center py-20">
                    <p class="text-2xl text-slate-400 mb-4">Nenhum post publicado ainda</p>
                    <p class="text-slate-500">Volte em breve para ver nossos artigos!</p>
                </div>
            ) : (
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 max-w-7xl mx-auto">
                    {posts.map((post) => {
                        // Usar thumbnail, com fallback para metaImage
                        const thumbnail = post.data.thumbnail || post.data.metaImage;
                        return (
                        <a 
                            href={`/blog/${post.id}`} 
                            class="group block p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all hover:bg-white/[0.08] hover:-translate-y-2"
                        >
                            {thumbnail ? (
                                <div class="mb-4 rounded-xl overflow-hidden aspect-video bg-white/5">
                                    <img 
                                        src={thumbnail} 
                                        alt={post.data.title}
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                        loading="lazy"
                                    />
                                </div>
                            ) : (
                                <div class="mb-4 rounded-xl overflow-hidden aspect-video bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center border border-white/10">
                                    <span class="text-4xl opacity-50">📝</span>
                                </div>
                            )}
                            <div class="mb-3">
                                {post.data.category && (
                                    <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-primary/20 text-primary border border-primary/30 rounded-full">
                                        {post.data.category}
                                    </span>
                                )}
                            </div>
                            <h2 class="text-xl font-bold text-white mb-3 group-hover:text-primary transition-colors leading-tight line-clamp-2">
                                {post.data.title}
                            </h2>
                            {post.data.metaDescription && (
                                <p class="text-slate-400 text-sm mb-4 line-clamp-2">
                                    {post.data.metaDescription}
                                </p>
                            )}
                            <div class="flex items-center justify-between text-sm text-slate-500">
                                {post.data.publishedDate && (
                                    <span>
                                        {new Date(post.data.publishedDate).toLocaleDateString('pt-BR', {
                                            day: '2-digit',
                                            month: 'short',
                                            year: 'numeric'
                                        })}
                                    </span>
                                )}
                                <span class="group-hover:translate-x-2 transition-transform duration-300 text-primary">
                                    Ler mais →
                                </span>
                            </div>
                        </a>
                        );
                    })}
                </div>
            )}
        </div>
    </section>

</MainLayout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
